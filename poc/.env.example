# ConnectWise PSA (sandbox)
CW_SITE=your-cw-instance.manage.us
CW_COMPANY_ID=your_company_id
CW_PUBLIC_KEY=your_public_key
CW_PRIVATE_KEY=your_private_key
CW_BOARD_ID=1

# Outbound webhook (Slack incoming webhook or custom)
WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
WEBHOOK_SECRET=change-me-in-production

# HITL threshold (seconds without human interaction before HITL-001 fires)
HITL_THRESHOLD_SEC=300
